# ===== 面板访问 =====
# 查看面板的密码，时序安全比较 (hmac.compare_digest)。
# 更防泄漏：改设 PANEL_PASSWORD_HASH（设了则优先、忽略明文）：
#   python -c "import hashlib;print(hashlib.sha256('yourpw'.encode()).hexdigest())"
PANEL_PASSWORD=change-me
# PANEL_PASSWORD_HASH=

# 签名会话 cookie 的密钥（务必改成随机值）：
#   python -c "import secrets;print(secrets.token_hex(32))"
PANEL_SESSION_SECRET=please-generate-a-random-64-char-secret
# 仅在 HTTPS 后端设 true（让 cookie 带 Secure）
PANEL_COOKIE_SECURE=false

# ===== 服务 =====
PORT=8000
CACHE_TTL_SECONDS=120
ADAPTER_TIMEOUT_SECONDS=10

# ===== OAuth 客户端凭据 =====
# 仅当运行 codex-web / google-oauth 渠道并触发 token 刷新时才用得到。
# 请从你本机已安装的对应桌面客户端中提取，然后填到下面（复制成 .env 后取消注释）：
#   Codex 桌面客户端:        CODEX_CLIENT_ID    (形如 app_EMoam...)
#   Antigravity 桌面客户端:  GOOGLE_CLIENT_ID   + GOOGLE_CLIENT_SECRET (形如 GOCSPX-...)
# CODEX_CLIENT_ID=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ===== 渠道 =====
# 每渠道：<NAME>_ENABLED, <NAME>_TYPE, <NAME>_API_KEY,
#        <NAME>_BASE_URL(可选；openai-relay 必填), <NAME>_LABEL
# 额外可选：<NAME>_REFRESH_TOKEN, <NAME>_ACCOUNT_ID, <NAME>_PROJECT_ID
# TYPE 取值：
#   siliconflow    硅基流动官方余额 (api.siliconflow.cn/v1/user/info, CNY)
#   codex-web      Codex ChatGPT Web: 需 ACCESS_TOKEN+可选REFRESH_TOKEN+ACCOUNT_ID
#   google-oauth   Google OAuth (Antigravity): 需 ACCESS_TOKEN+可选REFRESH_TOKEN+PROJECT_ID
#   pioneer        Pioneer.ai billing usage (GET /billing/usage/requests, X-API-Key auth)
#   openai-relay   OpenAI 兼容中转：需 BASE_URL，调 /v1/dashboard/billing/*
#   unsupported    无额度接口 → 卡片显示「暂不支持查询」
# ENABLED=false 整张卡隐藏；保持 true 展示全部 6 个。

# --- CODEX (codex / OpenAI 官方 sk- key) ---
CODEX_ENABLED=true
CODEX_TYPE=codex-web
# CODEX_API_KEY=<access_token>
# 若你的 codex key 实为中转 key，改为：CODEX_TYPE=openai-relay + CODEX_BASE_URL=https://your-relay
# CODEX_REFRESH_TOKEN=<refresh_token>
# CODEX_ACCOUNT_ID=<chatgpt_account_id>
CODEX_LABEL=Codex

# --- ANTIGRAVITY ---
ANTIGRAVITY_ENABLED=true
ANTIGRAVITY_TYPE=google-oauth
# ANTIGRAVITY_API_KEY=<google_oauth_access_token>
# ANTIGRAVITY_REFRESH_TOKEN=<google_refresh_token>
# ANTIGRAVITY_PROJECT_ID=<gcp_project_id>
ANTIGRAVITY_LABEL=Antigravity CLI

# --- GEMINI (Gemini CLI / AI Studio - 暂不支持) ---
GEMINI_ENABLED=true
GEMINI_TYPE=unsupported
# 若走中转：GEMINI_TYPE=openai-relay + GEMINI_BASE_URL=https://your-relay
# GEMINI_API_KEY=<google_oauth_access_token>
# GEMINI_REFRESH_TOKEN=<google_refresh_token>
# GEMINI_PROJECT_ID=<gcp_project_id>
GEMINI_LABEL=Gemini CLI

# --- GLM (智谱 — 暂不支持) ---
GLM_ENABLED=true
GLM_TYPE=unsupported
# GLM_API_KEY=<your_glm_api_key>
GLM_LABEL=智谱 GLM

# --- SILICONFLOW (硅基流动) ---
SILICONFLOW_ENABLED=true
SILICONFLOW_TYPE=siliconflow
# SILICONFLOW_API_KEY=<siliconflow_api_key>
SILICONFLOW_LABEL=硅基流动

# --- PIONEER.ai ---
PIONEER_ENABLED=true
PIONEER_TYPE=pioneer
# PIONEER_API_KEY=<pioneer_api_key>
PIONEER_LABEL=Pioneer.ai